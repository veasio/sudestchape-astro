---
import Default from '../../layouts/Default.astro';
import CtaRandom from '../../components/ui/CtaRandom.astro';
import { realisations, type Realisation } from '../../data/realisations';

export function getStaticPaths() {
  return realisations.map((r) => ({
    params: { slug: r.slug },
    props: { realisation: r },
  }));
}

interface Props {
  realisation: Realisation;
}

const { realisation: r } = Astro.props;

const starSvg = `<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
const stars = starSvg.repeat(5);

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": r.title,
  "description": r.description,
  "image": `https://www.sudestchape.fr${r.image}`,
  "author": {
    "@type": "Organization",
    "name": "Sud Est Chape"
  }
};
---

<Default
  title={`${r.title} | Sud Est Chape`}
  description={r.description}
  ogImage={r.image}
  schema={schema}
>

  {/* Image principale + header */}
  <section class="section section--rounded section--white" aria-label="Réalisation">
    <div class="container">
      <div class="project-detail">
        <div class="project-detail__hero">
          <img src={r.image}
               alt={r.title}
               width="1200" height="600"
               loading="eager"
               fetchpriority="high" />
        </div>

        <div class="project-detail__header">
          <h1 class="project-detail__title">{r.title}</h1>
          {r.location && <p class="project-detail__location">{r.location}</p>}
        </div>

        {/* Description + Caractéristiques */}
        <div class="project-detail__body">
          <div class="project-detail__description">
            <h2>Le projet</h2>
            <p>{r.description}</p>
          </div>

          <aside class="project-detail__specs" aria-labelledby="specs-title">
            <h2 id="specs-title">Caractéristiques</h2>
            <dl class="specs-list">
              <div class="specs-list__item">
                <dt>Type de chape</dt>
                <dd>{r.category}</dd>
              </div>
              {r.surface && (
                <div class="specs-list__item">
                  <dt>Surface</dt>
                  <dd>{r.surface}</dd>
                </div>
              )}
              {r.location && (
                <div class="specs-list__item">
                  <dt>Lieu</dt>
                  <dd>{r.location}</dd>
                </div>
              )}
              {r.date && (
                <div class="specs-list__item">
                  <dt>Période</dt>
                  <dd>{r.date}</dd>
                </div>
              )}
            </dl>
          </aside>
        </div>

        {/* Galerie photos */}
        <section class="project-detail__gallery" aria-labelledby="gallery-title">
          <h2 id="gallery-title">Photos du chantier</h2>
          <div class="grid grid--3">
            <figure class="project-detail__photo">
              <img src={r.image}
                   alt={`Préparation du sol – ${r.title}`}
                   width="600" height="400"
                   loading="lazy" />
              <figcaption>Préparation du sol</figcaption>
            </figure>
            <figure class="project-detail__photo">
              <img src={r.image}
                   alt={`Coulage de la chape – ${r.title}`}
                   width="600" height="400"
                   loading="lazy" />
              <figcaption>Coulage de la chape</figcaption>
            </figure>
            <figure class="project-detail__photo">
              <img src={r.image}
                   alt={`Résultat final – ${r.title}`}
                   width="600" height="400"
                   loading="lazy" />
              <figcaption>Résultat final</figcaption>
            </figure>
          </div>
        </section>
      </div>
    </div>
  </section>

  {/* Témoignage associé */}
  <section class="section section--accent section--rounded animate-on-scroll" aria-labelledby="realisation-testimonial-title">
    <div class="container">
      <h2 class="sr-only" id="realisation-testimonial-title">Témoignage client</h2>
      <div class="testimonial testimonial--featured" itemscope itemtype="https://schema.org/Review" style="max-width: 700px; margin-inline: auto;">
        <div class="testimonial__rating" aria-label="5 étoiles sur 5">
          <Fragment set:html={stars} />
        </div>
        <blockquote class="testimonial__quote" itemprop="reviewBody">
          Travail impeccable, équipe ponctuelle et professionnelle.
          La chape est parfaitement plane, idéale pour notre plancher chauffant.
          Je recommande vivement Sud Est Chape.
        </blockquote>
        <div class="testimonial__author">
          <div>
            <p class="testimonial__name" itemprop="author">Marc D.</p>
            <p class="testimonial__role">Propriétaire – {r.location ?? 'Sud-Est'}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* CTA aléatoire */}
  <CtaRandom />

</Default>
