---
import Default from '../layouts/Default.astro';
import MauticForm from '../components/ui/MauticForm.astro';
import { SITE_URL, SITE_PHONE, SITE_PHONE_DISPLAY, SITE_EMAIL, SITE_ADDRESS_HTML, MAUTIC_FORM_CONTACT_ID } from '../config';
import { realisations } from '../data/realisations';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Sud Est Chape",
  "description": "Contactez Sud Est Chape pour un devis gratuit de chape fluide ou traditionnelle.",
  "url": `${SITE_URL}/contact`
};

const chantiersMap = realisations.filter(r => r.lat && r.lng);
const mapData = JSON.stringify({
  company: { lat: 43.0977, lng: 6.0978, name: 'Sud Est Chape', address: '630 Chemin de Bassaquet, 83140 Six-Fours-les-Plages' },
  chantiers: chantiersMap.map(r => ({ lat: r.lat, lng: r.lng, title: r.title, location: r.location, category: r.category }))
});
---

<Default
  title="Contact - Devis gratuit chape | Sud Est Chape"
  description="Contactez Sud Est Chape pour un devis gratuit de chape liquide. Intervention dans le Var, Bouches-du-Rhone et Alpes-Maritimes."
  schema={schema}
>

  <section class="hero hero--small" aria-label="Nous contacter">
    <div class="hero__background">
      <img src="/images/optimized/hero-contact.webp"
           alt="Contactez Sud Est Chape"
           width="1920" height="600"
           loading="eager"
           fetchpriority="high" />
    </div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__overline">Parlons de votre projet</p>
        <h1 class="hero__title">Contactez-nous</h1>
        <p class="hero__description">
          Devis gratuit sous 48h, sans engagement.
          Nous intervenons dans tout le Sud-Est de la France.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--rounded section--white" aria-labelledby="contact-form-title">
    <div class="container">
      <h2 class="sr-only" id="contact-form-title">Formulaire de contact et coordonnees</h2>
      <div class="grid grid--2">

        {/* Colonne 1 - Formulaire */}
        <div class="contact-form" aria-labelledby="form-title">
          <div class="contact-form__header">
            <div class="contact-form__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <div class="contact-form__heading">
              <h3 id="form-title">Ecrivez-nous</h3>
            </div>
          </div>
          <p class="contact-form__note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Merci de preciser votre demande - tous les champs sont obligatoires et valides (email et telephone au bon format).
          </p>
          <MauticForm formId={MAUTIC_FORM_CONTACT_ID} />
        </div>

        {/* Colonne 2 - Coordonnees + CTA */}
        <div class="contact-info" aria-labelledby="info-title">
          <h3 id="info-title">Nos coordonnees</h3>

          <div class="contact-info__block">
            <h4 class="contact-info__label">Telephone</h4>
            <a href={`tel:${SITE_PHONE}`} class="contact-info__value contact-info__value--link">{SITE_PHONE_DISPLAY}</a>
          </div>

          <div class="contact-info__block">
            <h4 class="contact-info__label">Email</h4>
            <a href={`mailto:${SITE_EMAIL}`} class="contact-info__value contact-info__value--link">{SITE_EMAIL}</a>
          </div>

          <div class="contact-info__block">
            <h4 class="contact-info__label">Adresse</h4>
            <address class="contact-info__value" set:html={SITE_ADDRESS_HTML}></address>
          </div>

          <div class="contact-info__block">
            <h4 class="contact-info__label">Zone d'intervention</h4>
            <p class="contact-info__value">Var (83), Bouches-du-Rhone (13), Alpes-Maritimes (06), Vaucluse (84)</p>
          </div>

          <div class="contact-info__block">
            <h4 class="contact-info__label">Horaires</h4>
            <div class="opening-hours">
              <div class="opening-hours__row">
                <span class="opening-hours__days">Lun - Ven</span>
                <span class="opening-hours__time opening-hours__time--open">08h00 - 18h00</span>
              </div>
              <div class="opening-hours__row">
                <span class="opening-hours__days">Sam - Dim</span>
                <span class="opening-hours__time opening-hours__time--closed">Ferme</span>
              </div>
            </div>
          </div>

          {/* Zone flexible - CTA centre dans l'espace restant */}
          <div class="contact-info__cta-zone">
            <a href="/devis" class="contact-devis-cta" aria-label="Demarrer une demande de devis en ligne">
              <div class="contact-devis-cta__icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              </div>
              <div class="contact-devis-cta__body">
                <p class="contact-devis-cta__title">Demandez votre devis en ligne</p>
                <p class="contact-devis-cta__sub">
                  Chape anhydrite, ciment, ravoirage, isolation phonique &amp; thermique, mousse polyurethane - estimation precise, reponse sous 24h. Gratuit et sans engagement.
                </p>
              </div>
              <svg class="contact-devis-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* Carte interactive Leaflet en fond de section */}
  <section class="section--map-full animate-on-scroll" aria-labelledby="map-title">
    <div class="contact-map-full" id="contact-map" aria-hidden="true" data-map={mapData}></div>
    <div class="contact-map-overlay" aria-hidden="true"></div>
    <div class="container contact-map-content">
      <h2 class="section__title text-center" id="map-title">Notre zone d'intervention</h2>
      <p class="section__description text-center" style="margin-inline:auto; max-width:600px;">
        Var (83), Bouches-du-Rhone (13), Alpes-Maritimes (06), Vaucluse (84) - Bases a Six-Fours-les-Plages.
      </p>
    </div>
  </section>

  {/* Script Leaflet - DOIT etre a l'interieur du layout pour etre dans le <body> */}
  <script is:inline define:vars={{ mapData }}>
  (function () {
    function loadLeafletCSS() {
      if (document.querySelector('link[data-leaflet]')) return;
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.setAttribute('data-leaflet', '1');
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(link);
    }

    function initMap() {
      var el = document.getElementById('contact-map');
      if (!el || typeof L === 'undefined') return;

      var data;
      try { data = JSON.parse(mapData); } catch(e) { return; }

      var map = L.map('contact-map', { scrollWheelZoom: false, zoomControl: true }).setView([data.company.lat, data.company.lng], 10);
      // S'assurer que la carte remplit bien le conteneur absolu
      setTimeout(function() { map.invalidateSize(); }, 100);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 18
      }).addTo(map);

      var companyIcon = L.divIcon({
        className: 'map-company-marker',
        html: '<div class="map-company-pin"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>',
        iconSize: [44, 44],
        iconAnchor: [22, 44],
        popupAnchor: [0, -48]
      });

      L.marker([data.company.lat, data.company.lng], { icon: companyIcon })
        .addTo(map)
        .bindPopup(
          '<strong style="color:#ED4830;font-size:14px">Sud Est Chape</strong><br>' +
          '<span style="font-size:12px;color:#6b7280">' + data.company.address + '</span><br>' +
          '<a href="tel:+33494874041" style="color:#ED4830;font-size:12px;font-weight:600">04 94 87 40 41</a>'
        ).openPopup();

      if (data.chantiers && data.chantiers.length) {
        var chantierIcon = L.divIcon({
          className: 'map-company-marker',
          html: '<div style="width:12px;height:12px;background:#F27C22;border:2px solid white;border-radius:50%;box-shadow:0 2px 6px rgba(0,0,0,.3)"></div>',
          iconSize: [12, 12], iconAnchor: [6, 6], popupAnchor: [0, -10]
        });
        data.chantiers.forEach(function(c) {
          L.marker([c.lat, c.lng], { icon: chantierIcon }).addTo(map).bindPopup(
            '<strong style="font-size:13px">' + c.title + '</strong><br>' +
            '<span style="font-size:12px;color:#6b7280">' + (c.location || '') + ' - ' + (c.category || '') + '</span>'
          );
        });
      }
    }

    loadLeafletCSS();

    var s = document.createElement('script');
    s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    s.onload = initMap;
    document.head.appendChild(s);
  })();
  </script>

</Default>
