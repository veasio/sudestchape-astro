---
import Default from '../layouts/Default.astro';
import TestimonialsCompact from '../components/ui/TestimonialsCompact.astro';
import CtaRandom from '../components/ui/CtaRandom.astro';
import Stats from '../components/sections/Stats.astro';
import Engagements from '../components/sections/Engagements.astro';
import Steps from '../components/sections/Steps.astro';
import { SITE_NAME, SITE_URL, SITE_PHONE, SITE_PHONE_DISPLAY, SCHEMA_ORG_SAME_AS } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Chape liquide – ${SITE_NAME}`,
  "description": "Pose de chape liquide (anhydrite, ciment, ravoirage) et isolation phonique et thermique pour particuliers et professionnels dans le Sud-Est.",
  "provider": {
    "@type": "Organization",
    "name": SITE_NAME,
    "url": SITE_URL,
    "telephone": SITE_PHONE,
    "sameAs": SCHEMA_ORG_SAME_AS
  },
  "areaServed": "Sud-Est France"
};
---

<Default
  title="Nos Services Chape Liquide – Chapiste Agréé PACA | Sud Est Chape"
  description="Chape anhydrite, ciment, ravoirage, isolation phonique et thermique, mousse polyuréthane. Applicateur agréé dans le Var, BdR et Alpes-Maritimes."
  schema={schema}
>

  {/* Hero */}
  <section class="hero hero--small" aria-label="Nos services">
    <div class="hero__background">
      <img src="/images/optimized/hero-services.webp"
           alt="Services de chape par Sud Est Chape"
           width="1920" height="600"
           loading="eager"
           fetchpriority="high" />
    </div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__overline">Nos expertises</p>
        <h1 class="hero__title">Nos services de chape liquide dans le Sud-Est</h1>
        <p class="hero__description">
          Chape anhydrite, ciment, ravoirage, isolation phonique et thermique :
          6 équipes agréées interviennent pour les particuliers et professionnels dans tout le Sud-Est.
        </p>
      </div>
    </div>
  </section>

  {/* Services détaillés */}
  <section class="section section--rounded section--white" aria-labelledby="services-detail-title">
    <div class="container">
      <h2 class="sr-only" id="services-detail-title">Détail de nos services</h3>

      <div class="grid grid--3">
        {/* Chape Anhydrite */}
        <a href="/services/chape-anhydrite" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Chape Anhydrite</h3>
          <p class="card-service__text" itemprop="description">Solution de référence pour les planchers chauffants. Autonivelante, planéité parfaite, séchage rapide. Agréé Lafarge, Cemex et Vicat.</p>
          <ul class="card-service__features">
            <li>Planéité &lt; 3 mm sous règle de 2 m</li>
            <li>Compatible plancher chauffant/rafraîchissant</li>
            <li>Jusqu'à 1 000 m²/jour</li>
            <li>Séchage en 24-48h</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>

        {/* Chape Ciment */}
        <a href="/services/chape-ciment" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Chape Ciment</h3>
          <p class="card-service__text" itemprop="description">Robuste et polyvalente, la chape ciment s'adapte à toutes les configurations. Neuf ou rénovation, intérieur ou extérieur, milieux humides.</p>
          <ul class="card-service__features">
            <li>Neuf et rénovation</li>
            <li>Milieux humides (salle de bain, terrasse)</li>
            <li>Résistance mécanique élevée</li>
            <li>Conforme DTU 26.2</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>

        {/* Ravoirage / Réagréage */}
        <a href="/services/chape-reagreage-ravoirage" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 17l4-8 4 5 3-3 5 6"/>
              <line x1="3" y1="21" x2="21" y2="21"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Ravoirage &amp; Réagréage</h3>
          <p class="card-service__text" itemprop="description">Remise à niveau de sol avant pose de revêtement. Rattrapage de niveaux, comblement de dénivelés, préparation de chantier.</p>
          <ul class="card-service__features">
            <li>Rattrapage de niveaux</li>
            <li>Avant carrelage, parquet, résine</li>
            <li>Rénovation et neuf</li>
            <li>Compatible plancher chauffant</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>

        {/* Isolation Phonique */}
        <a href="/services/isolation-phonique" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M11 5L6 9H2v6h4l5 4V5z"/>
              <path d="M15.54 8.46a5 5 0 010 7.07"/>
              <path d="M19.07 4.93a10 10 0 010 14.14"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Isolation Phonique</h3>
          <p class="card-service__text" itemprop="description">Réduction des bruits de choc et d'impact entre étages. Sous-couches acoustiques + chape liquide pour une conformité optimale.</p>
          <ul class="card-service__features">
            <li>Bruits de choc réduits</li>
            <li>Norme NF DTU 26.2</li>
            <li>Copropriété et collectif</li>
            <li>Maisons individuelles</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>

        {/* Isolation Thermique */}
        <a href="/services/isolation-thermique" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Isolation Thermique</h3>
          <p class="card-service__text" itemprop="description">Réduction des déperditions thermiques par le sol. Compatible plancher chauffant, conforme RE 2020.</p>
          <ul class="card-service__features">
            <li>Économies d'énergie</li>
            <li>Compatible plancher chauffant</li>
            <li>Conforme RE 2020</li>
            <li>Neuf et rénovation</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>

        {/* Mousse Polyuréthane */}
        <a href="/services/mousse-polyurethane-projetee" class="card-service card-service--link" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Mousse Polyuréthane Projetée</h3>
          <p class="card-service__text" itemprop="description">Isolation par projection de mousse polyuréthane pour vides sanitaires, sous-sols et toitures-terrasses.</p>
          <ul class="card-service__features">
            <li>Vide sanitaire</li>
            <li>Étanchéité à l'air</li>
            <li>Isolation haute performance</li>
            <li>Toiture-terrasse</li>
          </ul>
          <span class="card-service__cta">En savoir plus →</span>
        </a>
      </div>
    </div>
  </section>

  {/* Chiffres clés */}
  <Stats
    stat1Count={500} stat1Suffix="+" stat1Label="Chantiers réalisés"
    stat2Count={15} stat2Suffix=" ans" stat2Label="D'expérience"
    stat3Count={6} stat3Suffix="" stat3Label="Équipes disponibles"
    stat4Count={3} stat4Suffix="" stat4Label="Départements couverts"
  />

  {/* Comment ça marche */}
  <Steps
    overline="Simple et rapide"
    title="Comment obtenir votre chape ?"
    titleId="steps-services-title"
    bg="gray"
    step1Title="Devis gratuit en 24h"
    step1Text="Remplissez notre formulaire ou appelez-nous. Un technicien vous rappelle sous 24h pour qualifier votre projet."
    step2Title="Visite technique offerte"
    step2Text="Déplacement gratuit sur votre chantier pour mesures, diagnostic du support et conseil technique personnalisé."
    step3Title="Intervention planifiée"
    step3Text="Date d'intervention fixée selon votre planning. Nos équipes arrivent avec tout le matériel nécessaire."
    step4Title="Réception et suivi"
    step4Text="Remise d'un bon de conformité, protocole de séchage et disponibilité pour toutes vos questions post-chantier."
  />

  {/* CTA double — appel ou devis */}
  <section class="section section--white section--rounded" aria-labelledby="cta-urgence-title">
    <div class="container">
      <div class="section__header">
        <p class="section__overline">Prêt à démarrer ?</p>
        <h2 class="section__title" id="cta-urgence-title">Parlez-nous de votre projet</h2>
        <p class="section__description" style="margin-inline:auto;">
          Devis gratuit sous 24h, intervention rapide, 6 équipes disponibles dans tout le Sud-Est.
        </p>
      </div>
      <div class="cta-dual">
        <a href={`tel:${SITE_PHONE}`} class="cta-dual__card cta-dual__card--phone">
          <div class="cta-dual__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 15.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 5h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 12.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.34 1.85.574 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div class="cta-dual__content">
            <span class="cta-dual__label">Appel direct</span>
            <strong class="cta-dual__value">{SITE_PHONE_DISPLAY}</strong>
            <span class="cta-dual__sub">Lun–Ven 8h–18h · Réponse immédiate</span>
          </div>
          <svg class="cta-dual__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/devis" class="cta-dual__card cta-dual__card--devis">
          <div class="cta-dual__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div class="cta-dual__content">
            <span class="cta-dual__label">Devis gratuit</span>
            <strong class="cta-dual__value">Réponse sous 24h</strong>
            <span class="cta-dual__sub">Sans engagement · Déplacement offert</span>
          </div>
          <svg class="cta-dual__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* Témoignages */}
  <TestimonialsCompact title="Ils ont fait confiance à nos services" />

  {/* CTA aléatoire */}
  <CtaRandom />

</Default>
