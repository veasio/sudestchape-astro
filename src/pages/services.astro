---
import Default from '../layouts/Default.astro';
import TestimonialsCompact from '../components/ui/TestimonialsCompact.astro';
import CtaRandom from '../components/ui/CtaRandom.astro';
import { SITE_NAME, SITE_URL, SITE_PHONE, SCHEMA_ORG_SAME_AS } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Chape fluide et traditionnelle – ${SITE_NAME}`,
  "description": "Pose de chape fluide autonivelante et chape ciment traditionnelle pour particuliers et professionnels dans le Sud-Est.",
  "provider": {
    "@type": "Organization",
    "name": SITE_NAME,
    "url": SITE_URL,
    "telephone": SITE_PHONE,
    "sameAs": SCHEMA_ORG_SAME_AS
  },
  "areaServed": "Sud-Est France"
};
---

<Default
  title="Nos services – Chape fluide et traditionnelle | Sud Est Chape"
  description="Découvrez nos services : chape fluide, chape traditionnelle, devis gratuit et qualité certifiée. Intervention dans tout le Sud-Est."
  schema={schema}
>

  {/* Hero */}
  <section class="hero hero--small" aria-label="Nos services">
    <div class="hero__background">
      <img src="/images/optimized/hero-services.webp"
           alt="Services de chape par Sud Est Chape"
           width="1920" height="600"
           loading="eager"
           fetchpriority="high" />
    </div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__overline">Nos expertises</p>
        <h1 class="hero__title">Des services adaptés à chaque projet</h1>
        <p class="hero__description">
          Chape fluide, chape traditionnelle, devis sur mesure :
          nous intervenons pour les particuliers et les professionnels dans tout le Sud-Est.
        </p>
      </div>
    </div>
  </section>

  {/* Services détaillés */}
  <section class="section section--rounded section--white animate-on-scroll" aria-labelledby="services-detail-title">
    <div class="container">
      <h2 class="sr-only" id="services-detail-title">Détail de nos services</h2>

      <div class="grid grid--2">
        {/* Chape fluide */}
        <div class="card-service" id="chape-fluide" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Chape fluide</h3>
          <p class="card-service__text" itemprop="description">
            La chape fluide autonivelante garantit une planéité parfaite sur de grandes surfaces.
            Idéale pour les planchers chauffants, elle assure une répartition homogène de la chaleur
            et un séchage rapide. Compatible avec tous types de revêtements de sol.
          </p>
          <ul class="card-service__features">
            <li>Planéité &lt; 3 mm sous règle de 2 m</li>
            <li>Compatible plancher chauffant</li>
            <li>Mise en œuvre rapide (jusqu'à 200 m²/jour)</li>
            <li>Séchage accéléré</li>
          </ul>
        </div>

        {/* Chape traditionnelle */}
        <div class="card-service" id="chape-traditionnelle" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Chape traditionnelle</h3>
          <p class="card-service__text" itemprop="description">
            La chape ciment tirée à la règle est la solution éprouvée pour tous types de sols.
            Robuste et polyvalente, elle s'adapte à toutes les configurations de chantier,
            en neuf comme en rénovation.
          </p>
          <ul class="card-service__features">
            <li>Adaptée neuf et rénovation</li>
            <li>Épaisseur sur mesure</li>
            <li>Résistance mécanique élevée</li>
            <li>Conforme aux normes DTU 26.2</li>
          </ul>
        </div>

        {/* Devis & chiffrage */}
        <div class="card-service" id="devis" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Devis &amp; chiffrage</h3>
          <p class="card-service__text" itemprop="description">
            Recevez une estimation précise et transparente pour votre projet.
            Notre technicien se déplace gratuitement sur votre chantier pour un relevé
            de mesures et un devis détaillé, sans engagement.
          </p>
          <ul class="card-service__features">
            <li>Devis gratuit sous 48h</li>
            <li>Visite technique offerte</li>
            <li>Prix ferme et définitif</li>
            <li>Sans engagement</li>
          </ul>
        </div>

        {/* Qualité certifiée */}
        <div class="card-service" id="qualite" itemscope itemtype="https://schema.org/Service">
          <div class="card-service__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3 class="card-service__title" itemprop="name">Qualité certifiée</h3>
          <p class="card-service__text" itemprop="description">
            Nous utilisons exclusivement des matériaux haut de gamme et nos équipes
            sont formées aux dernières techniques. Chaque chantier est contrôlé
            pour garantir un résultat conforme aux normes en vigueur.
          </p>
          <ul class="card-service__features">
            <li>Matériaux certifiés NF</li>
            <li>Équipes qualifiées et formées</li>
            <li>Respect des normes DTU</li>
            <li>Garantie décennale</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Témoignages */}
  <TestimonialsCompact title="Ils ont fait confiance à nos services" />

  {/* CTA aléatoire */}
  <CtaRandom />

</Default>
