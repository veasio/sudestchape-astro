---
import Default from '../layouts/Default.astro';
---
<Default
  title="Devis en ligne — Sud Est Chape"
  description="Calculez votre devis de chape fluide ou traditionnelle en quelques clics."
>
  <section class="section">
    <div class="container" style="text-align:center; padding: 4rem 1rem;">
      <h1>Calculateur de devis</h1>
      <p style="margin-top:1rem; color:#737373;">Cette fonctionnalité sera disponible prochainement.</p>
      <a href="/contact" class="btn btn--primary" style="margin-top:2rem; display:inline-flex;">Demander un devis par email</a>
    </div>
  </section>
</Default>
