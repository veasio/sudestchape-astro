---
import Default from '../layouts/Default.astro';
import MauticForm from '../components/ui/MauticForm.astro';
import Stats from '../components/sections/Stats.astro';
import { SITE_URL, SITE_PHONE, SITE_PHONE_DISPLAY, MAUTIC_FORM_DEVIS_ID, SITE_NAME } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Devis gratuit chape liquide – ${SITE_NAME}`,
  "description": "Demandez un devis gratuit pour votre chape liquide. Réponse sous 24h, visite technique offerte.",
  "url": `${SITE_URL}/devis`
};
---

<Default
  title="Devis Gratuit Chape Liquide – Réponse 24h | Sud Est Chape"
  description="Demandez votre devis gratuit pour chape anhydrite, ciment, ravoirage ou isolation. Réponse sous 24h, visite technique offerte, sans engagement."
  schema={schema}
>

  {/* Hero */}
  <section class="hero hero--small" aria-label="Demander un devis">
    <div class="hero__background">
      <img src="/images/optimized/hero-contact.webp"
           alt="Demandez un devis gratuit – Sud Est Chape"
           width="1920" height="600"
           loading="eager"
           fetchpriority="high" />
    </div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__overline">Gratuit & sans engagement</p>
        <h1 class="hero__title">Votre devis chape liquide gratuit</h1>
        <p class="hero__description">
          Réponse sous 24h · Visite technique offerte · 6 équipes disponibles dans le Sud-Est
        </p>
      </div>
    </div>
  </section>

  {/* Formulaire de devis */}
  <section class="section section--rounded section--white" aria-labelledby="devis-form-title">
    <div class="container">
      <div class="devis-layout">

        {/* Colonne gauche : Formulaire */}
        <div class="devis-layout__form">
          <h2 id="devis-form-title" class="devis-layout__title">Décrivez votre projet</h2>
          <p class="devis-layout__subtitle">
            Plus vous nous donnez de détails, plus notre devis sera précis et adapté à vos besoins.
          </p>
          <MauticForm formId={MAUTIC_FORM_DEVIS_ID} />
        </div>

        {/* Colonne droite : Réassurance */}
        <aside class="devis-layout__aside">
          <div class="devis-aside">
            <h3 class="devis-aside__title">Pourquoi nous choisir ?</h3>

            <ul class="devis-aside__list">
              <li class="devis-aside__item">
                <span class="devis-aside__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <div>
                  <strong>Réponse sous 24h</strong>
                  <span>Un technicien vous rappelle rapidement</span>
                </div>
              </li>
              <li class="devis-aside__item">
                <span class="devis-aside__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <div>
                  <strong>Visite technique offerte</strong>
                  <span>Déplacement gratuit sur votre chantier</span>
                </div>
              </li>
              <li class="devis-aside__item">
                <span class="devis-aside__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <div>
                  <strong>Sans engagement</strong>
                  <span>Devis gratuit, aucune obligation</span>
                </div>
              </li>
              <li class="devis-aside__item">
                <span class="devis-aside__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <div>
                  <strong>Applicateur agréé</strong>
                  <span>Lafarge, Cemex, Vicat, Bonifay</span>
                </div>
              </li>
            </ul>

            <div class="devis-aside__cta">
              <p class="devis-aside__cta-label">Préférez-vous nous appeler ?</p>
              <a href={`tel:${SITE_PHONE}`} class="btn btn--primary btn--full">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 15.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 5h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 12.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.34 1.85.574 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                {SITE_PHONE_DISPLAY}
              </a>
              <p class="devis-aside__cta-sub">Lun–Ven · 8h–18h</p>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  {/* Chiffres clés */}
  <Stats
    stat1Count={1000} stat1Suffix="+" stat1Label="Chantiers réalisés"
    stat2Count={15} stat2Suffix=" ans" stat2Label="D'expérience"
    stat3Count={6} stat3Suffix="" stat3Label="Équipes disponibles"
    stat4Count={3} stat4Suffix="" stat4Label="Départements couverts"
  />

</Default>

<style>
.devis-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--spacing-10);
  align-items: start;
}

@media (max-width: 1023px) {
  .devis-layout {
    grid-template-columns: 1fr;
  }
}

.devis-layout__title {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--color-gray-900);
  margin-bottom: var(--spacing-2);
}

.devis-layout__subtitle {
  color: var(--color-gray-600);
  margin-bottom: var(--spacing-6);
}

/* Aside réassurance */
.devis-aside {
  background: var(--color-gray-50);
  border: 1px solid var(--color-gray-200);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-6);
}

.devis-aside__title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-gray-900);
  margin-bottom: var(--spacing-5);
}

.devis-aside__list {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--spacing-6);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-4);
}

.devis-aside__item {
  display: flex;
  gap: var(--spacing-3);
  align-items: flex-start;
}

.devis-aside__icon {
  width: 32px;
  height: 32px;
  background: var(--color-primary);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.devis-aside__item strong {
  display: block;
  font-weight: 600;
  color: var(--color-gray-900);
  font-size: var(--text-sm);
}

.devis-aside__item span {
  font-size: var(--text-xs);
  color: var(--color-gray-600);
}

.devis-aside__cta {
  border-top: 1px solid var(--color-gray-200);
  padding-top: var(--spacing-5);
  text-align: center;
}

.devis-aside__cta-label {
  font-size: var(--text-sm);
  color: var(--color-gray-600);
  margin-bottom: var(--spacing-3);
}

.devis-aside__cta-sub {
  font-size: var(--text-xs);
  color: var(--color-gray-500);
  margin-top: var(--spacing-2);
}
</style>
