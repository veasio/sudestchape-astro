---
import { getCollection } from 'astro:content';
import Default from '../layouts/Default.astro';
import TestimonialsCompact from '../components/ui/TestimonialsCompact.astro';
import CtaRandom from '../components/ui/CtaRandom.astro';
import { SITE_URL } from '../config';

const realisations = (await getCollection('realisations'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Nos realisations de chape - Sud Est Chape",
  "description": "Decouvrez nos realisations de chape fluide et traditionnelle dans le Sud-Est. Photos de chantiers dans le Var, Bouches-du-Rhone et Alpes-Maritimes.",
  "url": `${SITE_URL}/realisations`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Sud Est Chape",
    "url": SITE_URL
  }
};
---

<Default
  title="Nos realisations - Chantiers de chape | Sud Est Chape"
  description="Decouvrez nos realisations de chape fluide et traditionnelle dans le Sud-Est. Photos de chantiers, details techniques et resultats dans le Var, Bouches-du-Rhone et Alpes-Maritimes."
  schema={schema}
>

  <section class="hero hero--small" aria-label="Nos realisations">
    <div class="hero__background">
      <img src="/images/optimized/hero-realisations.webp"
           alt="Realisations de chape par Sud Est Chape"
           width="1920" height="600"
           loading="eager"
           fetchpriority="high" />
    </div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__overline">Portfolio</p>
        <h1 class="hero__title">Nos realisations</h1>
        <p class="hero__description">
          Particuliers, professionnels, logements neufs ou renovation :
          decouvrez nos chantiers recents dans tout le Sud-Est.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--rounded section--white" aria-labelledby="realisations-list-title">
    <div class="container">
      <h2 class="sr-only" id="realisations-list-title">Liste de nos realisations</h2>

      <div class="grid grid--3">
        {realisations.map((r) => (
          <a href={`/realisations/${r.slug}`} class="card-project">
            <div class="card-project__image">
              <img
                src={r.data.images[0].src}
                alt={r.data.images[0].alt}
                width="600" height="400"
                loading="lazy"
              />
            </div>
            <div class="card-project__content">
              <p class="card-project__type">{r.data.category}</p>
              <h3 class="card-project__title">{r.data.title}</h3>
              <p class="card-project__location">{r.data.city} ({r.data.departmentCode}) - {r.data.surface}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <TestimonialsCompact title="Nos clients temoignent" />

  <CtaRandom />

</Default>
