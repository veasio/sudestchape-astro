---
import { SITE_NAME, SITE_PHONE, SITE_PHONE_DISPLAY } from '../config';

interface Props {
  title?: string;
  errorCode?: string | number;
  description?: string;
}
const {
  title = 'Page introuvable',
  errorCode = '404',
  description = 'La page que vous recherchez n\'existe pas ou a été déplacée.',
} = Astro.props;
---
<!doctype html>
<html lang="fr" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title} — {SITE_NAME}</title>

  {/* noindex : ne pas indexer les pages d'erreur */}
  <meta name="robots" content="noindex, nofollow" />

  {/* Favicon */}
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />

  {/* Preconnect Google Fonts */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" />

  {/* CSS inline complet (pas de fichier externe pour les erreurs = 1 requête en moins) */}
  <style>
    :root {
      --color-primary: #CB6015;
      --color-accent: #F5E0CF;
      --color-cta: #F27C22;
      --color-white: #ffffff;
      --color-gray-100: #f5f5f5;
      --color-gray-200: #e5e5e5;
      --color-gray-500: #737373;
      --color-gray-700: #404040;
      --color-gray-900: #171717;

      --font-family: 'Inter', sans-serif;
      --font-weight-regular: 400;
      --font-weight-medium: 500;
      --font-weight-bold: 700;
      --font-weight-black: 900;

      --fs-sm: 0.875rem;
      --fs-base: clamp(1rem, 0.81rem + 0.16vw, 1.125rem);
      --fs-lg: clamp(1.125rem, 0.87rem + 0.32vw, 1.375rem);
      --fs-xl: clamp(1.25rem, 1rem + 0.5vw, 1.75rem);
      --fs-2xl: clamp(1.5rem, 1.1rem + 0.8vw, 2.25rem);
      --fs-3xl: clamp(1.875rem, 1.3rem + 1.2vw, 3rem);

      --spacing-2: 0.5rem;
      --spacing-4: 1rem;
      --spacing-6: 1.5rem;
      --spacing-8: 2rem;
      --spacing-12: 3rem;
      --spacing-16: 4rem;

      --page-padding: 1.25rem;
      --max-width: 720px;
      --border-radius: 0.5rem;
      --transition-base: 200ms ease-in-out;
    }

    @media (min-width: 1024px) {
      :root { --page-padding: 2rem; }
    }

    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--font-family);
      font-size: var(--fs-base);
      font-weight: var(--font-weight-regular);
      line-height: 1.6;
      color: var(--color-gray-900);
      background-color: var(--color-gray-100);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    img, svg { display: block; max-width: 100%; }

    :focus-visible {
      outline: 3px solid var(--color-cta);
      outline-offset: 2px;
    }

    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap; border: 0;
    }

    /* Error header */
    .error-header {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--spacing-4) var(--page-padding);
      background: var(--color-white);
      border-bottom: 1px solid var(--color-gray-200);
    }
    .error-header__logo img { height: 2.5rem; width: auto; }
    .error-header__logo-text {
      font-size: var(--fs-xl);
      font-weight: var(--font-weight-bold);
      color: var(--color-primary);
      text-decoration: none;
    }

    /* Error content */
    .error-content {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--spacing-16) var(--page-padding);
      text-align: center;
    }
    .error-content__inner {
      max-width: var(--max-width);
    }
    .error-content__code {
      font-size: clamp(4rem, 10vw, 8rem);
      font-weight: var(--font-weight-black);
      line-height: 1;
      color: var(--color-primary);
      letter-spacing: -0.025em;
    }
    .error-content__title {
      font-size: var(--fs-2xl);
      font-weight: var(--font-weight-bold);
      margin-top: var(--spacing-4);
      color: var(--color-gray-900);
    }
    .error-content__description {
      font-size: var(--fs-lg);
      color: var(--color-gray-500);
      margin-top: var(--spacing-4);
      max-width: 480px;
      margin-inline: auto;
    }
    .error-content__actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--spacing-4);
      justify-content: center;
      margin-top: var(--spacing-8);
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--spacing-2);
      padding: 0.75rem 1.5rem;
      font-size: var(--fs-base);
      font-weight: var(--font-weight-medium);
      text-decoration: none;
      border-radius: 3.75rem;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background-color var(--transition-base),
                  color var(--transition-base),
                  border-color var(--transition-base);
    }
    .btn--primary {
      background: var(--color-primary);
      color: var(--color-white);
      border-color: var(--color-primary);
    }
    .btn--primary:hover {
      background: var(--color-cta);
      border-color: var(--color-cta);
    }
    .btn--outline {
      background: transparent;
      color: var(--color-gray-700);
      border-color: var(--color-gray-200);
    }
    .btn--outline:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    /* Error footer */
    .error-footer {
      text-align: center;
      padding: var(--spacing-6) var(--page-padding);
      background: var(--color-white);
      border-top: 1px solid var(--color-gray-200);
      font-size: var(--fs-sm);
      color: var(--color-gray-500);
    }
    .error-footer a {
      color: var(--color-primary);
      text-decoration: none;
    }
    .error-footer a:hover { text-decoration: underline; }
  </style>
</head>

<body class="layout-error">

  {/* Header : logo seul */}
  <header class="error-header" role="banner">
    <a href="/" aria-label={`${SITE_NAME} - Retour à l'accueil`}>
      <span class="error-header__logo-text">{SITE_NAME}</span>
    </a>
  </header>

  {/* Contenu principal */}
  <main id="main-content" role="main" class="error-content">
    <div class="error-content__inner">
      <p class="error-content__code" aria-label={`Erreur ${errorCode}`}>{errorCode}</p>
      <h1 class="error-content__title">{title}</h1>
      <p class="error-content__description">{description}</p>
      <div class="error-content__actions">
        <a href="/" class="btn btn--primary">Retour à l'accueil</a>
        <a href="/contact" class="btn btn--outline">Nous contacter</a>
      </div>
      <slot />
    </div>
  </main>

  {/* Footer minimal */}
  <footer class="error-footer" role="contentinfo">
    <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Tous droits réservés.</p>
    <p>
      Besoin d'aide ? Appelez-nous au
      <a href={`tel:${SITE_PHONE}`}>{SITE_PHONE_DISPLAY}</a>
    </p>
  </footer>

</body>
</html>
