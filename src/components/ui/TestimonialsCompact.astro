---
// Témoignages compacts (3 avis)
// Source : partials/testimonials-compact.htm

interface Props {
  title?: string;
}

const { title = 'Ce que disent nos clients' } = Astro.props;

const starSvg = `<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
const stars = starSvg.repeat(5);
---

<section class="section section--white section--rounded animate-on-scroll" aria-labelledby="testimonials-compact-title">
  <div class="container">
    <div class="section__header">
      <p class="section__overline">Avis clients</p>
      <h2 class="section__title" id="testimonials-compact-title">
        {title}
      </h2>
    </div>

    <div class="grid grid--3">
      <div class="testimonial" itemscope itemtype="https://schema.org/Review">
        <div class="testimonial__rating" aria-label="5 étoiles sur 5">
          <Fragment set:html={stars} />
        </div>
        <blockquote class="testimonial__quote" itemprop="reviewBody">
          Travail impeccable, équipe ponctuelle et professionnelle.
          La chape est parfaitement plane, idéale pour notre plancher chauffant.
        </blockquote>
        <div class="testimonial__author">
          <div>
            <p class="testimonial__name" itemprop="author">Marc D.</p>
            <p class="testimonial__role">Particulier &ndash; Aix-en-Provence</p>
          </div>
        </div>
      </div>

      <div class="testimonial" itemscope itemtype="https://schema.org/Review">
        <div class="testimonial__rating" aria-label="5 étoiles sur 5">
          <Fragment set:html={stars} />
        </div>
        <blockquote class="testimonial__quote" itemprop="reviewBody">
          Nous faisons appel à Sudest Chape pour tous nos chantiers.
          Fiabilité, qualité et prix compétitifs. Un vrai partenaire.
        </blockquote>
        <div class="testimonial__author">
          <div>
            <p class="testimonial__name" itemprop="author">Sophie L.</p>
            <p class="testimonial__role">Entreprise de construction &ndash; Marseille</p>
          </div>
        </div>
      </div>

      <div class="testimonial" itemscope itemtype="https://schema.org/Review">
        <div class="testimonial__rating" aria-label="5 étoiles sur 5">
          <Fragment set:html={stars} />
        </div>
        <blockquote class="testimonial__quote" itemprop="reviewBody">
          Réactivité exemplaire et résultat au top. La chape fluide
          a été coulée en une journée. Je recommande vivement.
        </blockquote>
        <div class="testimonial__author">
          <div>
            <p class="testimonial__name" itemprop="author">Philippe R.</p>
            <p class="testimonial__role">Particulier &ndash; Toulon</p>
          </div>
        </div>
      </div>
    </div>

    {/* Lien vers plus d'avis */}
    <div class="text-center" style="margin-top: var(--spacing-8);">
      <a href="/#testimonials-title" class="btn btn--outline">
        Voir tous les avis
      </a>
    </div>
  </div>
</section>
