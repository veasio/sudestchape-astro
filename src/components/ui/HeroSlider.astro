---
import { HEADER_TRANSPARENT } from '../../config';
import { heroSlides } from '../../data/hero-slides';

const headerTransparentEnabled = HEADER_TRANSPARENT;
const total = heroSlides.length;
---

<div class={`hero-wrapper${headerTransparentEnabled ? ' hero-wrapper--transparent-mode' : ''}`}>
  <section class="hero hero--full hero-slider"
           role="region"
           aria-roledescription="carousel"
           aria-label="Présentation de l'entreprise">

    {heroSlides.map((slide, i) => (
      <div
        class={[
          'hero-slider__slide',
          i === 0 ? 'hero-slider__slide--active' : '',
          slide.contentAlign === 'right' ? 'hero-slider__slide--content-right' : '',
        ].filter(Boolean).join(' ')}
        role="group"
        aria-roledescription="slide"
        aria-label={`Slide ${i + 1} sur ${total}`}
      >
        <div class="hero__background">
          <img
            src={slide.image}
            alt={slide.imageAlt}
            width="1920"
            height="1080"
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : undefined}
          />
        </div>
        <div class="container">
          <div class="hero__content">
            <p class="hero__overline">{slide.overline}</p>
            <h2 class="hero__title" set:html={slide.title} />
            <p class="hero__description" set:html={slide.description} />
            <div class="hero__actions">
              <a href={slide.ctaPrimary.url} class="btn btn--cta btn--lg">
                {slide.ctaPrimary.label}
              </a>
              {slide.ctaSecondary && (
                <a href={slide.ctaSecondary.url} class="btn btn--white btn--lg">
                  {slide.ctaSecondary.label}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}

    {/* Navigation flèches */}
    <button type="button" class="hero-slider__arrow hero-slider__arrow--prev" aria-label="Slide précédent">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button type="button" class="hero-slider__arrow hero-slider__arrow--next" aria-label="Slide suivant">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="9 6 15 12 9 18"/>
      </svg>
    </button>

    {/* Dots */}
    <div class="hero-slider__dots" role="tablist" aria-label="Slides">
      {heroSlides.map((_, i) => (
        <button
          type="button"
          class={`hero-slider__dot${i === 0 ? ' hero-slider__dot--active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>

  </section>
</div>
