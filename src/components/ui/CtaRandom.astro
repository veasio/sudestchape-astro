---
// CTA aléatoire — 3 variantes : devis, telephone, realisations
// Source : partials/cta-random.htm + partials/cta/*.htm
// La sélection aléatoire se fait côté client via un script inline
// (Astro est statique — pas de random côté serveur)

import { SITE_PHONE, SITE_PHONE_DISPLAY } from '../../config';
---

{/* Les 3 variantes sont toutes rendues, JS côté client en affiche une au hasard */}
<div id="cta-random-wrapper">
  {/* Variante devis */}
  <section id="cta-devis" class="section section--accent animate-on-scroll" aria-labelledby="cta-devis-title" style="display:none">
    <div class="container text-center">
      <h2 class="section__title" id="cta-devis-title">
        Un projet de chape dans le Sud-Est ?
      </h2>
      <p class="section__description" style="margin-inline:auto;">
        Obtenez votre devis gratuit sous 24h. 6 équipes disponibles, intervention rapide sur Var, Bouches-du-Rhône et Alpes-Maritimes.
      </p>
      <div class="hero__actions mt-8" style="justify-content:center;">
        <a href="/devis" class="btn btn--primary btn--lg">
          Obtenir mon devis gratuit
        </a>
      </div>
    </div>
  </section>

  {/* Variante telephone */}
  <section id="cta-telephone" class="section section--accent animate-on-scroll" aria-labelledby="cta-telephone-title" style="display:none">
    <div class="container text-center">
      <h2 class="section__title" id="cta-telephone-title">
        Vous avez un projet ? On vous répond.
      </h2>
      <p class="section__description" style="margin-inline:auto;">
        Appelez directement notre équipe pour un conseil, une évaluation de faisabilité ou un délai d'intervention. Disponible lun–ven 8h–18h.
      </p>
      <div class="hero__actions mt-8" style="justify-content:center;">
        <a href={`tel:${SITE_PHONE}`} class="btn btn--primary btn--lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {SITE_PHONE_DISPLAY}
        </a>
        <a href="/contact" class="btn btn--outline btn--lg">
          Nous envoyer un message
        </a>
      </div>
    </div>
  </section>

  {/* Variante realisations */}
  <section id="cta-realisations" class="section section--accent animate-on-scroll" aria-labelledby="cta-realisations-title" style="display:none">
    <div class="container text-center">
      <h2 class="section__title" id="cta-realisations-title">
        1 000+ chantiers réalisés dans le Sud-Est
      </h2>
      <p class="section__description" style="margin-inline:auto;">
        De la villa particulière aux grandes surfaces industrielles, retrouvez nos réalisations et découvrez la qualité de notre savoir-faire.
      </p>
      <div class="hero__actions mt-8" style="justify-content:center;">
        <a href="/realisations" class="btn btn--primary btn--lg">
          Voir nos réalisations
        </a>
        <a href="/devis" class="btn btn--outline btn--lg">
          Obtenir un devis gratuit
        </a>
      </div>
    </div>
  </section>
</div>

<script is:inline>
(function () {
  var variants = ['cta-devis', 'cta-telephone', 'cta-realisations'];
  var random = variants[Math.floor(Math.random() * variants.length)];
  var el = document.getElementById(random);
  if (el) el.style.display = '';
})();
</script>
