<script>
(function () {
  const STORAGE_KEY = 'devis_wizard_v1';

  // ── État du wizard ──
  const state = {
    currentStep: 1,
    totalSteps: 6,
    data: {},
    partialSubmitted: false,
  };

  // ── Éléments DOM ──
  const wizard   = document.getElementById('devis-wizard');
  if (!wizard) return;

  const mauticUrl     = wizard.dataset.mauticUrl;
  const formContactId = wizard.dataset.formContactId;
  const formContactName = wizard.dataset.formContactName;
  const formDevisId   = wizard.dataset.formDevisId;
  const formDevisName = wizard.dataset.formDevisName;

  const panels      = wizard.querySelectorAll('.wizard__panel');
  const navDots     = wizard.querySelectorAll('[data-nav-step]');
  const progressFill = document.getElementById('wizard-progress-fill');
  const btnBack     = document.getElementById('wizard-btn-back');
  const btnNext     = document.getElementById('wizard-btn-next');
  const btnSubmit   = document.getElementById('wizard-btn-submit');
  const successDiv  = document.getElementById('wizard-success');
  const errorDiv    = document.getElementById('wizard-error');
  const errorText   = document.getElementById('wizard-error-text');
  const navBar      = document.getElementById('wizard-nav');

  // ── Restauration depuis sessionStorage ──
  try {
    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved) {
      const parsed = JSON.parse(saved);
      Object.assign(state.data, parsed.data || {});
      state.partialSubmitted = parsed.partialSubmitted || false;
    }
  } catch (_) {}

  function saveState() {
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        data: state.data,
        partialSubmitted: state.partialSubmitted,
      }));
    } catch (_) {}
  }

  // ── Affichage d'une étape ──
  function showStep(n) {
    state.currentStep = n;

    panels.forEach(p => {
      const step = parseInt(p.dataset.step);
      p.classList.toggle('wizard__panel--hidden', step !== n);
    });

    // Avancement de la barre
    const pct = ((n - 1) / (state.totalSteps - 1)) * 100;
    if (progressFill) progressFill.style.width = pct + '%';

    // Points de navigation
    navDots.forEach(dot => {
      const s = parseInt(dot.dataset.navStep);
      dot.classList.toggle('wizard__step-dot--active', s === n);
      dot.classList.toggle('wizard__step-dot--done', s < n);
      dot.setAttribute('aria-current', s === n ? 'step' : null);
    });

    // Boutons
    btnBack.style.visibility = n > 1 ? 'visible' : 'hidden';
    const isLast = n === state.totalSteps;
    btnNext.classList.toggle('wizard__panel--hidden', isLast);
    btnSubmit.classList.toggle('wizard__panel--hidden', !isLast);
    if (isLast) buildSummary();

    hideError();
    restoreStepValues(n);
  }

  // ── Restauration des valeurs saisies ──
  function restoreStepValues(n) {
    const panel = wizard.querySelector(`[data-step="${n}"]`);
    if (!panel) return;

    panel.querySelectorAll('input[name], select[name], textarea[name]').forEach(el => {
      const val = state.data[el.name];
      if (val === undefined) return;
      if (el.type === 'radio') {
        el.checked = el.value === val;
      } else {
        el.value = val;
      }
    });

    // Champ accès conditionnel
    if (n === 4) {
      const accesVal = state.data['acces_difficile'];
      toggleAccesDetail(accesVal === 'difficile' || accesVal === 'a_preciser');
    }
    // Badge recommandé
    if (n === 3) {
      updateRecommendationBadge();
    }
  }

  // ── Collecte des valeurs de l'étape courante ──
  function collectStep(n) {
    const panel = wizard.querySelector(`[data-step="${n}"]`);
    if (!panel) return;

    panel.querySelectorAll('input[name], select[name], textarea[name]').forEach(el => {
      if (el.type === 'radio') {
        if (el.checked) state.data[el.name] = el.value;
      } else if (el.value.trim() !== '') {
        state.data[el.name] = el.value.trim();
      }
    });
    saveState();
  }

  // ── Validation de l'étape ──
  function validateStep(n) {
    const panel = wizard.querySelector(`[data-step="${n}"]`);
    if (!panel) return true;
    let valid = true;

    if (n === 1) {
      const fn = panel.querySelector('#wz-firstname');
      const em = panel.querySelector('#wz-email');
      [fn, em].forEach(el => {
        if (!el.value.trim()) {
          el.classList.add('wizard__input--error');
          valid = false;
        } else {
          el.classList.remove('wizard__input--error');
        }
      });
      if (!valid) showError('Veuillez remplir les champs obligatoires (prénom, email).');
    }

    if (n === 2) {
      const checked = panel.querySelector('input[name="type_projet"]:checked');
      if (!checked) {
        valid = false;
        showError('Veuillez sélectionner un type de construction.');
      }
    }

    if (n === 3) {
      const checked = panel.querySelector('input[name="type_chape"]:checked');
      if (!checked) {
        valid = false;
        showError('Veuillez sélectionner un type de prestation.');
      }
    }

    if (n === 4) {
      const surf = panel.querySelector('#wz-surface');
      if (!surf.value) {
        surf.classList.add('wizard__input--error');
        valid = false;
        showError('Veuillez indiquer la surface en m².');
      } else {
        surf.classList.remove('wizard__input--error');
      }
    }

    return valid;
  }

  // ── Messages d'erreur ──
  function showError(msg) {
    errorText.textContent = msg;
    errorDiv.classList.remove('wizard__panel--hidden');
  }

  function hideError() {
    errorDiv.classList.add('wizard__panel--hidden');
  }

  // ── Affichage conditionnel du champ accès ──
  function toggleAccesDetail(show) {
    const field = document.getElementById('acces-detail-field');
    if (field) field.style.display = show ? 'flex' : 'none';
  }

  // ── Badge recommandé ──
  function updateRecommendationBadge() {
    const badge = document.getElementById('badge-anhydrite');
    if (!badge) return;
    const hasPlancher = state.data['plancher_chauffant'] === 'oui';
    badge.classList.toggle('wizard__card-badge--hidden', !hasPlancher);
    if (hasPlancher) {
      const step3Desc = document.getElementById('step3-desc');
      if (step3Desc) step3Desc.textContent = 'La chape anhydrite est recommandée pour les planchers chauffants.';
    }
  }

  // ── Soumission partielle (étape 1 → formulaire contact) ──
  async function submitPartial() {
    if (state.partialSubmitted) return;
    const fd = new FormData();
    fd.append('mauticform[formId]', formContactId);
    fd.append('mauticform[formName]', formContactName);
    fd.append('mauticform[return]', '');
    ['firstname', 'lastname', 'email', 'phone'].forEach(k => {
      if (state.data[k]) fd.append(`mauticform[${k}]`, state.data[k]);
    });

    try {
      await fetch(`${mauticUrl}/form/submit?formId=${formContactId}`, {
        method: 'POST',
        body: fd,
        mode: 'no-cors',
      });
      state.partialSubmitted = true;
      saveState();
    } catch (_) {
      // Silencieux — ne pas bloquer la navigation
    }
  }

  // ── Soumission finale (étape 6 → formulaire devis) ──
  async function submitFinal() {
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Envoi en cours…';
    hideError();

    const fd = new FormData();
    fd.append('mauticform[formId]', formDevisId);
    fd.append('mauticform[formName]', formDevisName);
    fd.append('mauticform[return]', '');

    const fields = [
      'firstname','lastname','email','phone',
      'type_chape','surface_m2','epaisseur_mm',
      'adresse_chantier','ville_chantier','code_postal_chantier',
      'departement','acces_difficile','description_acces',
      'type_projet','date_intervention','message',
    ];
    fields.forEach(k => {
      if (state.data[k]) fd.append(`mauticform[${k}]`, state.data[k]);
    });

    try {
      await fetch(`${mauticUrl}/form/submit?formId=${formDevisId}`, {
        method: 'POST',
        body: fd,
        mode: 'no-cors',
      });

      // Succès (no-cors = on ne peut pas lire la réponse, on suppose OK)
      sessionStorage.removeItem(STORAGE_KEY);
      panels.forEach(p => p.classList.add('wizard__panel--hidden'));
      successDiv.classList.remove('wizard__panel--hidden');
      wizard.querySelector('.wizard__progress').style.display = 'none';
      navBar.style.display = 'none';
    } catch (err) {
      showError('Une erreur réseau est survenue. Veuillez réessayer ou nous appeler directement.');
      btnSubmit.disabled = false;
      btnSubmit.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Envoyer ma demande`;
    }
  }

  // ── Construction du récapitulatif ──
  const LABELS = {
    type_projet: { neuf: 'Construction neuve', renovation: 'Rénovation', les_deux: 'Les deux' },
    plancher_chauffant: { oui: 'Oui', non: 'Non' },
    type_chape: {
      chape_anhydrite: 'Chape Anhydrite', chape_ciment: 'Chape Ciment',
      ravoirage: 'Ravoirage / Réagréage', isolation_phonique: 'Isolation Phonique',
      isolation_thermique: 'Isolation Thermique', mousse_polyurethane: 'Mousse Polyuréthane',
      autre: 'Autre / Je ne sais pas',
    },
    departement: { '83': 'Var (83)', '13': 'Bouches-du-Rhône (13)', '06': 'Alpes-Maritimes (06)', '84': 'Vaucluse (84)', autre: 'Autre' },
    acces_difficile: { normal: 'Normal', difficile: 'Difficile', a_preciser: 'À préciser' },
    date_intervention: {
      urgent: 'Dès que possible', '1_mois': 'Dans 1 mois',
      '2_3_mois': 'Dans 2–3 mois', '3_6_mois': 'Dans 3–6 mois', indetermine: 'Non déterminé',
    },
  };

  function label(key, val) {
    return LABELS[key]?.[val] || val || '—';
  }

  function buildSummary() {
    const d = state.data;
    const container = document.getElementById('wizard-summary');
    if (!container) return;

    const blocks = [
      {
        title: 'Vos coordonnées', step: 1,
        rows: [
          ['Prénom', d.firstname], ['Nom', d.lastname],
          ['Email', d.email], ['Téléphone', d.phone],
        ],
      },
      {
        title: 'Votre projet', step: 2,
        rows: [
          ['Type', label('type_projet', d.type_projet)],
          ['Plancher chauffant', label('plancher_chauffant', d.plancher_chauffant)],
        ],
      },
      {
        title: 'Prestation', step: 3,
        rows: [['Type de chape', label('type_chape', d.type_chape)]],
      },
      {
        title: 'Chantier', step: 4, fullWidth: true,
        rows: [
          ['Surface', d.surface_m2 ? d.surface_m2 + ' m²' : null],
          ['Épaisseur', d.epaisseur_mm ? d.epaisseur_mm + ' mm' : null],
          ['Adresse', d.adresse_chantier],
          ['Ville / CP', [d.ville_chantier, d.code_postal_chantier].filter(Boolean).join(' ')],
          ['Département', label('departement', d.departement)],
          ['Accès', label('acces_difficile', d.acces_difficile)],
          d.description_acces ? ['Détails accès', d.description_acces] : null,
        ].filter(Boolean),
      },
      {
        title: 'Planning', step: 5,
        rows: [
          ['Intervention', label('date_intervention', d.date_intervention)],
          d.message ? ['Commentaire', d.message] : null,
        ].filter(Boolean),
      },
    ];

    container.innerHTML = blocks.map(b => `
      <div class="wizard__summary-block ${b.fullWidth ? 'wizard__summary-block--full' : ''}">
        <p class="wizard__summary-title">${b.title}</p>
        ${b.rows.map(r => r && r[1] ? `
          <div class="wizard__summary-row">
            <span class="wizard__summary-key">${r[0]}</span>
            <span class="wizard__summary-val">${r[1]}</span>
          </div>` : ''
        ).join('')}
        <button class="wizard__summary-edit" data-goto="${b.step}" aria-label="Modifier ${b.title}">Modifier</button>
      </div>
    `).join('');

    // Boutons "Modifier"
    container.querySelectorAll('[data-goto]').forEach(btn => {
      btn.addEventListener('click', () => showStep(parseInt(btn.dataset.goto)));
    });
  }

  // ── Événements ──

  btnNext.addEventListener('click', async () => {
    collectStep(state.currentStep);
    if (!validateStep(state.currentStep)) return;

    if (state.currentStep === 1) {
      submitPartial(); // feu et oublie
    }

    if (state.currentStep === 2) {
      updateRecommendationBadge();
    }

    showStep(state.currentStep + 1);
  });

  btnBack.addEventListener('click', () => {
    collectStep(state.currentStep);
    showStep(state.currentStep - 1);
  });

  btnSubmit.addEventListener('click', () => {
    submitFinal();
  });

  // Accès difficile — champ conditionnel
  wizard.querySelectorAll('input[name="acces_difficile"]').forEach(radio => {
    radio.addEventListener('change', () => {
      toggleAccesDetail(radio.value === 'difficile' || radio.value === 'a_preciser');
    });
  });

  // ── Init ──
  showStep(1);
})();
</script>
