---
import { MAUTIC_BASE_URL } from '../../config';

const mauticUrl = MAUTIC_BASE_URL;
---

<div
  class="wizard"
  id="devis-wizard"
  data-mautic-url={mauticUrl}
  data-form-contact-id="2"
  data-form-contact-name="formulairecontact"
  data-form-devis-id="4"
  data-form-devis-name="formulairedevis"
>

  {/* Indicateur de progression */}
  <div class="wizard__progress" aria-label="Étapes du formulaire">
    <div class="wizard__steps-nav" role="list">
      {[
        { n: 1, label: 'Contact' },
        { n: 2, label: 'Projet' },
        { n: 3, label: 'Prestation' },
        { n: 4, label: 'Chantier' },
        { n: 5, label: 'Planning' },
        { n: 6, label: 'Récap' },
      ].map(({ n, label }) => (
        <div class="wizard__step-dot" data-nav-step={n} role="listitem" aria-current={n === 1 ? 'step' : undefined}>
          <div class="wizard__step-circle">
            <span class="wizard__step-num">{n}</span>
            <svg class="wizard__step-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="wizard__step-label">{label}</span>
        </div>
      ))}
    </div>
    <div class="wizard__progress-track" aria-hidden="true">
      <div class="wizard__progress-fill" id="wizard-progress-fill"></div>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 1 : Contact ─────────────────── */}
  <div class="wizard__panel" data-step="1">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 1 sur 6</p>
      <h2 class="wizard__panel-title">Vos coordonnées</h2>
      <p class="wizard__panel-desc">Nous vous enverrons votre devis par email. L'email est obligatoire.</p>
    </div>
    <div class="wizard__fields">
      <div class="wizard__row">
        <div class="wizard__field">
          <label class="wizard__label" for="wz-firstname">Prénom <span aria-hidden="true">*</span></label>
          <input class="wizard__input" type="text" id="wz-firstname" name="firstname"
                 autocomplete="given-name" required placeholder="Jean" />
        </div>
        <div class="wizard__field">
          <label class="wizard__label" for="wz-lastname">Nom</label>
          <input class="wizard__input" type="text" id="wz-lastname" name="lastname"
                 autocomplete="family-name" placeholder="Dupont" />
        </div>
      </div>
      <div class="wizard__field">
        <label class="wizard__label" for="wz-email">Email <span class="wizard__label-req" aria-hidden="true">*</span></label>
        <input class="wizard__input" type="email" id="wz-email" name="email"
               autocomplete="email" required placeholder="jean.dupont@email.fr" />
        <p class="wizard__hint">Votre devis vous sera envoyé à cette adresse.</p>
      </div>
      <div class="wizard__field">
        <label class="wizard__label" for="wz-phone">Téléphone</label>
        <input class="wizard__input" type="tel" id="wz-phone" name="phone"
               autocomplete="tel" placeholder="06 12 34 56 78" />
      </div>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 2 : Projet ─────────────────── */}
  <div class="wizard__panel wizard__panel--hidden" data-step="2">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 2 sur 6</p>
      <h2 class="wizard__panel-title">Votre projet</h2>
      <p class="wizard__panel-desc">Dites-nous en plus sur la nature de votre chantier.</p>
    </div>

    <div class="wizard__fields">
      <fieldset class="wizard__fieldset">
        <legend class="wizard__legend">Type de construction <span aria-hidden="true">*</span></legend>
        <div class="wizard__cards wizard__cards--3" role="radiogroup" aria-label="Type de construction">
          <label class="wizard__card" data-value="neuf">
            <input type="radio" name="type_projet" value="neuf" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <span class="wizard__card-title">Construction neuve</span>
          </label>
          <label class="wizard__card" data-value="renovation">
            <input type="radio" name="type_projet" value="renovation" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <span class="wizard__card-title">Rénovation</span>
          </label>
          <label class="wizard__card" data-value="les_deux">
            <input type="radio" name="type_projet" value="les_deux" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <span class="wizard__card-title">Les deux</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="wizard__fieldset">
        <legend class="wizard__legend">Plancher chauffant ?</legend>
        <div class="wizard__toggle-group" role="radiogroup" aria-label="Plancher chauffant">
          <label class="wizard__toggle">
            <input type="radio" name="plancher_chauffant" value="oui" class="wizard__toggle-radio" />
            <span class="wizard__toggle-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Oui
            </span>
          </label>
          <label class="wizard__toggle">
            <input type="radio" name="plancher_chauffant" value="non" class="wizard__toggle-radio" />
            <span class="wizard__toggle-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Non
            </span>
          </label>
        </div>
        <p class="wizard__hint">Cette information nous aide à vous recommander la meilleure solution.</p>
      </fieldset>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 3 : Type de prestation ─────────────────── */}
  <div class="wizard__panel wizard__panel--hidden" data-step="3">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 3 sur 6</p>
      <h2 class="wizard__panel-title">Type de prestation</h2>
      <p class="wizard__panel-desc" id="step3-desc">Sélectionnez la prestation souhaitée.</p>
    </div>
    <div class="wizard__fields">
      <div class="wizard__cards wizard__cards--2" role="radiogroup" aria-label="Type de prestation" aria-describedby="step3-desc">
        <label class="wizard__card wizard__card--service" data-value="chape_anhydrite">
          <input type="radio" name="type_chape" value="chape_anhydrite" class="wizard__card-radio" />
          <span class="wizard__card-badge wizard__card-badge--hidden" id="badge-anhydrite">★ Recommandé</span>
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span class="wizard__card-title">Chape Anhydrite</span>
          <span class="wizard__card-sub">Autonivelante · Plancher chauffant</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="chape_ciment">
          <input type="radio" name="type_chape" value="chape_ciment" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <span class="wizard__card-title">Chape Ciment</span>
          <span class="wizard__card-sub">Robuste · Milieux humides</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="ravoirage">
          <input type="radio" name="type_chape" value="ravoirage" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 17l4-8 4 5 3-3 5 6"/>
              <line x1="3" y1="21" x2="21" y2="21"/>
            </svg>
          </div>
          <span class="wizard__card-title">Ravoirage / Réagréage</span>
          <span class="wizard__card-sub">Remise à niveau · Rattrapage</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="isolation_phonique">
          <input type="radio" name="type_chape" value="isolation_phonique" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M11 5L6 9H2v6h4l5 4V5z"/>
              <path d="M15.54 8.46a5 5 0 010 7.07"/>
            </svg>
          </div>
          <span class="wizard__card-title">Isolation Phonique</span>
          <span class="wizard__card-sub">Bruits de choc · DTU 26.2</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="isolation_thermique">
          <input type="radio" name="type_chape" value="isolation_thermique" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
            </svg>
          </div>
          <span class="wizard__card-title">Isolation Thermique</span>
          <span class="wizard__card-sub">RE 2020 · Économies d'énergie</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="mousse_polyurethane">
          <input type="radio" name="type_chape" value="mousse_polyurethane" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <span class="wizard__card-title">Mousse Polyuréthane</span>
          <span class="wizard__card-sub">Vide sanitaire · Toiture-terrasse</span>
        </label>
        <label class="wizard__card wizard__card--service" data-value="autre">
          <input type="radio" name="type_chape" value="autre" class="wizard__card-radio" />
          <div class="wizard__card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <span class="wizard__card-title">Autre / Je ne sais pas</span>
          <span class="wizard__card-sub">Nous vous conseillons</span>
        </label>
      </div>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 4 : Chantier ─────────────────── */}
  <div class="wizard__panel wizard__panel--hidden" data-step="4">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 4 sur 6</p>
      <h2 class="wizard__panel-title">Votre chantier</h2>
      <p class="wizard__panel-desc">Ces informations nous permettent de calculer votre devis avec précision.</p>
    </div>
    <div class="wizard__fields">
      <div class="wizard__row">
        <div class="wizard__field">
          <label class="wizard__label" for="wz-surface">Surface totale (m²) <span aria-hidden="true">*</span></label>
          <div class="wizard__input-wrap">
            <input class="wizard__input wizard__input--unit" type="number" id="wz-surface"
                   name="surface_m2" min="1" max="9999" required placeholder="150" />
            <span class="wizard__input-suffix" aria-hidden="true">m²</span>
          </div>
        </div>
        <div class="wizard__field">
          <label class="wizard__label" for="wz-epaisseur">Épaisseur souhaitée (mm)</label>
          <div class="wizard__input-wrap">
            <input class="wizard__input wizard__input--unit" type="number" id="wz-epaisseur"
                   name="epaisseur_mm" min="20" max="200" placeholder="40" />
            <span class="wizard__input-suffix" aria-hidden="true">mm</span>
          </div>
          <p class="wizard__hint">En général : 40–70 mm pour chape standard, 35–50 mm avec plancher chauffant.</p>
        </div>
      </div>
      <div class="wizard__field">
        <label class="wizard__label" for="wz-adresse">Adresse du chantier</label>
        <input class="wizard__input" type="text" id="wz-adresse" name="adresse_chantier"
               autocomplete="street-address" placeholder="123 rue de la Chape" />
      </div>
      <div class="wizard__row wizard__row--3">
        <div class="wizard__field">
          <label class="wizard__label" for="wz-ville">Ville</label>
          <input class="wizard__input" type="text" id="wz-ville" name="ville_chantier"
                 autocomplete="address-level2" placeholder="Toulon" />
        </div>
        <div class="wizard__field">
          <label class="wizard__label" for="wz-cp">Code postal</label>
          <input class="wizard__input" type="text" id="wz-cp" name="code_postal_chantier"
                 autocomplete="postal-code" inputmode="numeric" maxlength="5" placeholder="83000" />
        </div>
        <div class="wizard__field">
          <label class="wizard__label" for="wz-dept">Département</label>
          <select class="wizard__select" id="wz-dept" name="departement">
            <option value="">-- Choisir --</option>
            <option value="83">Var (83)</option>
            <option value="13">Bouches-du-Rhône (13)</option>
            <option value="06">Alpes-Maritimes (06)</option>
            <option value="84">Vaucluse (84)</option>
            <option value="autre">Autre</option>
          </select>
        </div>
      </div>
      <fieldset class="wizard__fieldset">
        <legend class="wizard__legend">Accès au chantier</legend>
        <div class="wizard__cards wizard__cards--3" role="radiogroup" aria-label="Accès au chantier">
          <label class="wizard__card wizard__card--sm" data-value="normal">
            <input type="radio" name="acces_difficile" value="normal" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 17H5a2 2 0 00-2 2v0a2 2 0 002 2h14a2 2 0 002-2v0a2 2 0 00-2-2h-4"/>
                <path d="M9 1h6v12H9zM9 7h6"/>
              </svg>
            </div>
            <span class="wizard__card-title">Normal</span>
            <span class="wizard__card-sub">Accès standard</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="difficile">
            <input type="radio" name="acces_difficile" value="difficile" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <span class="wizard__card-title">Difficile</span>
            <span class="wizard__card-sub">Étages, escaliers…</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="a_preciser">
            <input type="radio" name="acces_difficile" value="a_preciser" class="wizard__card-radio" />
            <div class="wizard__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <span class="wizard__card-title">À préciser</span>
            <span class="wizard__card-sub">Je vais détailler</span>
          </label>
        </div>
        <div class="wizard__field wizard__field--conditional" id="acces-detail-field" style="display:none">
          <label class="wizard__label" for="wz-acces-desc">Précisez l'accès</label>
          <input class="wizard__input" type="text" id="wz-acces-desc" name="description_acces"
                 placeholder="Ex : 3e étage sans ascenseur, accès par l'arrière…" />
        </div>
      </fieldset>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 5 : Planning ─────────────────── */}
  <div class="wizard__panel wizard__panel--hidden" data-step="5">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 5 sur 6</p>
      <h2 class="wizard__panel-title">Planning et détails</h2>
      <p class="wizard__panel-desc">Quand souhaitez-vous que nous intervenions ?</p>
    </div>
    <div class="wizard__fields">
      <fieldset class="wizard__fieldset">
        <legend class="wizard__legend">Date d'intervention souhaitée</legend>
        <div class="wizard__cards wizard__cards--3" role="radiogroup" aria-label="Date d'intervention">
          <label class="wizard__card wizard__card--sm" data-value="urgent">
            <input type="radio" name="date_intervention" value="urgent" class="wizard__card-radio" />
            <span class="wizard__card-title">Dès que possible</span>
            <span class="wizard__card-sub">Urgent</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="1_mois">
            <input type="radio" name="date_intervention" value="1_mois" class="wizard__card-radio" />
            <span class="wizard__card-title">Dans 1 mois</span>
            <span class="wizard__card-sub">Sous 4 semaines</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="2_3_mois">
            <input type="radio" name="date_intervention" value="2_3_mois" class="wizard__card-radio" />
            <span class="wizard__card-title">Dans 2–3 mois</span>
            <span class="wizard__card-sub">En cours de préparation</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="3_6_mois">
            <input type="radio" name="date_intervention" value="3_6_mois" class="wizard__card-radio" />
            <span class="wizard__card-title">Dans 3–6 mois</span>
            <span class="wizard__card-sub">Projet en cours</span>
          </label>
          <label class="wizard__card wizard__card--sm" data-value="indetermine">
            <input type="radio" name="date_intervention" value="indetermine" class="wizard__card-radio" />
            <span class="wizard__card-title">Je ne sais pas encore</span>
            <span class="wizard__card-sub">À définir</span>
          </label>
        </div>
      </fieldset>
      <div class="wizard__field">
        <label class="wizard__label" for="wz-message">Informations complémentaires</label>
        <textarea class="wizard__textarea" id="wz-message" name="message" rows="4"
                  placeholder="Précisez votre projet, contraintes particulières, questions…"></textarea>
      </div>
    </div>
  </div>

  {/* ─────────────────── ÉTAPE 6 : Récapitulatif ─────────────────── */}
  <div class="wizard__panel wizard__panel--hidden" data-step="6">
    <div class="wizard__panel-header">
      <p class="wizard__panel-overline">Étape 6 sur 6</p>
      <h2 class="wizard__panel-title">Récapitulatif</h2>
      <p class="wizard__panel-desc">Vérifiez vos informations avant d'envoyer votre demande.</p>
    </div>
    <div class="wizard__summary" id="wizard-summary">
      {/* Rempli dynamiquement */}
    </div>
    <div class="wizard__submit-area">
      <p class="wizard__privacy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
        Vos données sont confidentielles et ne seront jamais partagées.
      </p>
    </div>
  </div>

  {/* Message de succès */}
  <div class="wizard__success wizard__panel--hidden" id="wizard-success" role="alert" aria-live="polite">
    <div class="wizard__success-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
    </div>
    <h2 class="wizard__success-title">Demande envoyée !</h2>
    <p class="wizard__success-text">
      Merci pour votre demande. Un technicien vous contactera sous 24h pour affiner votre devis.
    </p>
    <a href="/" class="btn btn--primary" style="margin-top: var(--spacing-6);">Retour à l'accueil</a>
  </div>

  {/* Navigation (boutons Précédent / Suivant / Envoyer) */}
  <div class="wizard__nav" id="wizard-nav">
