---
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  subtitle?: string;
  titleId?: string;
  bg?: 'gray' | 'white' | 'accent';
  ctaLabel?: string;
  ctaUrl?: string;
}

const {
  title = 'Nos dernières réalisations',
  subtitle = 'Découvrez nos chantiers récents dans le Sud-Est',
  titleId = 'realisations-title',
  bg = 'gray',
  ctaLabel = 'Voir tout',
  ctaUrl = '/realisations',
} = Astro.props;

const items = (await getCollection('realisations'))
  .filter((r) => r.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<section class={`section section--${bg} section--rounded animate-on-scroll`} aria-labelledby={titleId}>
  <div class="container">
    <div class="realisations-feed">
      <div class="realisations-feed__header">
        <div class="realisations-feed__title-group">
          <div class="realisations-feed__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div>
            <h2 class="realisations-feed__title" id={titleId}>{title}</h2>
            <p class="realisations-feed__subtitle">{subtitle}</p>
          </div>
        </div>
        <a href={ctaUrl} class="btn btn--primary">
          {ctaLabel}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="realisations-feed__track">
        {items.map((r) => (
          <div class="realisations-feed__item">
            <img
              src={r.data.images[0].src}
              alt={r.data.images[0].alt}
              width="400" height="400"
              loading="lazy"
            />
            <div class="realisations-feed__overlay">
              <p class="realisations-feed__item-title">{r.data.title.split(' - ').pop()}</p>
              <p class="realisations-feed__item-location">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {r.data.city} • {r.data.surface}
              </p>
            </div>
            <a href={`/realisations/${r.slug}`} class="realisations-feed__link" aria-label={`Voir la réalisation : ${r.data.title}`}></a>
          </div>
        ))}
      </div>

      <button type="button" class="realisations-feed__nav realisations-feed__nav--prev" aria-label="Voir les réalisations précédentes" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <button type="button" class="realisations-feed__nav realisations-feed__nav--next" aria-label="Voir les réalisations suivantes">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>
