---
interface Props {
  title?: string;
  subtitle?: string;
  titleId?: string;
  bg?: 'gray' | 'white' | 'accent';
  ctaLabel?: string;
  ctaUrl?: string;
}

const {
  title = 'Nos dernières réalisations',
  subtitle = 'Découvrez nos chantiers récents dans le Sud-Est',
  titleId = 'realisations-title',
  bg = 'gray',
  ctaLabel = 'Voir tout',
  ctaUrl = '/realisations',
} = Astro.props;

const items = [
  { img: '/images/optimized/realisation-1.webp', alt: 'Chape fluide villa contemporaine Aix-en-Provence', itemTitle: 'Villa contemporaine', location: 'Aix-en-Provence • 180 m²', ariaLabel: 'Voir la réalisation villa contemporaine' },
  { img: '/images/optimized/realisation-2.webp', alt: "Chape traditionnelle entrepôt Marseille", itemTitle: 'Entrepôt logistique', location: 'Marseille • 850 m²', ariaLabel: 'Voir la réalisation entrepôt logistique' },
  { img: '/images/optimized/realisation-3.webp', alt: 'Plancher chauffant appartement Nice', itemTitle: 'Appartement rénové', location: 'Nice • 95 m²', ariaLabel: 'Voir la réalisation appartement rénové' },
  { img: '/images/optimized/realisation-4.webp', alt: 'Chape fluide résidence collective Toulon', itemTitle: 'Résidence collective', location: 'Toulon • 1200 m²', ariaLabel: 'Voir la réalisation résidence collective' },
  { img: '/images/optimized/realisation-5.webp', alt: 'Maison individuelle plancher chauffant Cannes', itemTitle: 'Maison individuelle', location: 'Cannes • 220 m²', ariaLabel: 'Voir la réalisation maison individuelle' },
  { img: '/images/optimized/realisation-6.webp', alt: 'Local commercial chape Avignon', itemTitle: 'Local commercial', location: 'Avignon • 350 m²', ariaLabel: 'Voir la réalisation local commercial' },
  { img: '/images/optimized/realisation-7.webp', alt: 'Chape garage Montpellier', itemTitle: 'Garage automobile', location: 'Montpellier • 480 m²', ariaLabel: 'Voir la réalisation garage automobile' },
  { img: '/images/optimized/realisation-8.webp', alt: "Bureaux entreprise Marseille", itemTitle: "Bureaux d'entreprise", location: 'Marseille • 620 m²', ariaLabel: "Voir la réalisation bureaux d'entreprise" },
];
---

<section class={`section section--${bg} section--rounded animate-on-scroll`} aria-labelledby={titleId}>
  <div class="container">
    <div class="realisations-feed">
      <div class="realisations-feed__header">
        <div class="realisations-feed__title-group">
          <div class="realisations-feed__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div>
            <h2 class="realisations-feed__title" id={titleId}>{title}</h2>
            <p class="realisations-feed__subtitle">{subtitle}</p>
          </div>
        </div>
        <a href={ctaUrl} class="btn btn--primary">
          {ctaLabel}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="realisations-feed__track">
        {items.map((item) => (
          <div class="realisations-feed__item">
            <img src={item.img} alt={item.alt} width="400" height="400" loading="lazy" />
            <div class="realisations-feed__overlay">
              <p class="realisations-feed__item-title">{item.itemTitle}</p>
              <p class="realisations-feed__item-location">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {item.location}
              </p>
            </div>
            <a href={ctaUrl} class="realisations-feed__link" aria-label={item.ariaLabel}></a>
          </div>
        ))}
      </div>

      <button type="button" class="realisations-feed__nav realisations-feed__nav--prev" aria-label="Voir les réalisations précédentes" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <button type="button" class="realisations-feed__nav realisations-feed__nav--next" aria-label="Voir les réalisations suivantes">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>
