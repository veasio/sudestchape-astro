---
interface Props {
  variant?: 'image-left' | 'image-right';
  overline?: string;
  title: string;
  titleId?: string;
  text?: string;
  image: string;
  imageAlt?: string;
  listItem1?: string;
  listItem2?: string;
  listItem3?: string;
  listItem4?: string;
  listItem5?: string;
  ctaLabel?: string;
  ctaUrl?: string;
  ctaStyle?: 'white' | 'primary' | 'outline';
}

const {
  variant = 'image-left',
  overline = '',
  title,
  titleId = 'split-title',
  text = '',
  image,
  imageAlt = '',
  listItem1 = '',
  listItem2 = '',
  listItem3 = '',
  listItem4 = '',
  listItem5 = '',
  ctaLabel = '',
  ctaUrl = '/contact',
  ctaStyle = 'white',
} = Astro.props;
---

<section
  class={`split-section${variant === 'image-right' ? ' split-section--reverse' : ''} animate-on-scroll`}
  aria-labelledby={titleId}
>
  <div class="split-section__image">
    <img
      src={image}
      alt={imageAlt}
      width="960"
      height="640"
      loading="lazy"
    />
  </div>
  <div class="split-section__content">
    {overline && <p class="split-section__overline">{overline}</p>}
    <h2 class="split-section__title" id={titleId}>{title}</h2>
    {text && <p class="split-section__text" set:html={text} />}
    {listItem1 && (
      <ul class="split-section__list">
        <li>{listItem1}</li>
        {listItem2 && <li>{listItem2}</li>}
        {listItem3 && <li>{listItem3}</li>}
        {listItem4 && <li>{listItem4}</li>}
        {listItem5 && <li>{listItem5}</li>}
      </ul>
    )}
    {ctaLabel && (
      <a href={ctaUrl} class={`btn btn--${ctaStyle} btn--lg`}>
        {ctaLabel}
      </a>
    )}
  </div>
</section>
