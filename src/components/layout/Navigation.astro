---
// Navigation principale (desktop)
// Source : partials/navigation.htm

import { NAV_ITEMS } from '../../config';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const menuItems = NAV_ITEMS;
---

<nav class="main-nav" role="navigation" aria-label="Navigation principale">
  <ul class="main-nav__list" role="list">
    {menuItems.map((item) => {
      const isActive = currentPath === item.url;
      const isChildActive = item.items?.some(child => currentPath === child.url) ?? false;
      return (
        <li class={`main-nav__item${isActive || isChildActive ? ' is-active' : ''}`}>
          <a href={item.url}
             class="main-nav__link"
             aria-current={isActive ? 'page' : undefined}
             aria-expanded={item.items ? 'false' : undefined}
             aria-haspopup={item.items ? 'true' : undefined}>
            {item.title}
          </a>
          {item.items && (
            <ul class="main-nav__submenu" role="list">
              {item.items.map((child) => (
                <li class="main-nav__subitem">
                  <a href={child.url}
                     class="main-nav__sublink"
                     aria-current={currentPath === child.url ? 'page' : undefined}>
                    {child.title}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      );
    })}
  </ul>
</nav>
