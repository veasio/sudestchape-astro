---
// Top bar avec accroches promotionnelles défilantes
// Source : partials/top-bar.htm

import {
  SITE_PHONE, SITE_PHONE_DISPLAY,
  TOPBAR_LEFT_TEXT,
  PROMO_ENABLED, PROMO_AUTOPLAY, PROMO_INTERVAL_MS, PROMO_PAUSE_ON_HOVER,
  PROMO_MESSAGES,
} from '../../config';

const sitePhone = SITE_PHONE_DISPLAY;
const sitePhoneRaw = SITE_PHONE;
const promoMessages = PROMO_MESSAGES;
---

<div class="top-bar" role="banner" aria-label="Informations et promotions">
  <div class="top-bar__inner container">

    {/* Colonne gauche : Slogan/Tagline */}
    <div class="top-bar__col top-bar__col--left">
      <span class="top-bar__tagline">{TOPBAR_LEFT_TEXT}</span>
    </div>

    {/* Colonne centrale : Messages promotionnels défilants */}
    <div class="top-bar__col top-bar__col--center">
      <div class="promo-carousel"
           data-autoplay={String(PROMO_AUTOPLAY)}
           data-interval={String(Math.round(PROMO_INTERVAL_MS / 1000))}
           data-pause-on-hover={String(PROMO_PAUSE_ON_HOVER)}
           aria-live="polite"
           aria-atomic="true">

        {/* Flèche gauche */}
        <button type="button"
                class="promo-carousel__nav promo-carousel__nav--prev"
                aria-label="Message précédent">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>

        {/* Container des slides */}
        <div class="promo-carousel__track">
          {promoMessages.map((message, index) => (
            <div class={`promo-carousel__slide${index === 0 ? ' is-active' : ''}`}
                 data-index={index}
                 aria-hidden={index !== 0 ? 'true' : undefined}>
              {message.link ? (
                <a href={message.link} class="promo-carousel__link">
                  {message.icon === 'truck' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'percent' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="5" x2="5" y2="19"></line>
                        <circle cx="6.5" cy="6.5" r="2.5"></circle>
                        <circle cx="17.5" cy="17.5" r="2.5"></circle>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'star' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'shield' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      </svg>
                    </span>
                  )}
                  <span class="promo-carousel__text">{message.text}</span>
                </a>
              ) : (
                <>
                  {message.icon === 'truck' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'percent' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="5" x2="5" y2="19"></line>
                        <circle cx="6.5" cy="6.5" r="2.5"></circle>
                        <circle cx="17.5" cy="17.5" r="2.5"></circle>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'star' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                      </svg>
                    </span>
                  )}
                  {message.icon === 'shield' && (
                    <span class="promo-carousel__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      </svg>
                    </span>
                  )}
                  <span class="promo-carousel__text">{message.text}</span>
                </>
              )}
            </div>
          ))}
        </div>

        {/* Flèche droite */}
        <button type="button"
                class="promo-carousel__nav promo-carousel__nav--next"
                aria-label="Message suivant">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>

    {/* Colonne droite : Téléphone */}
    <div class="top-bar__col top-bar__col--right">
      <a href={`tel:${sitePhoneRaw}`} class="top-bar__phone">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span>{sitePhone}</span>
      </a>
    </div>

  </div>
</div>
