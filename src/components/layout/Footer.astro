---
// Footer principal
// Source : partials/footer.htm

import MauticForm from '../ui/MauticForm.astro';
import {
  SITE_NAME, SITE_DESCRIPTION, SITE_PHONE, SITE_PHONE_DISPLAY, SITE_EMAIL, SITE_ADDRESS_HTML,
  SOCIAL_FACEBOOK, SOCIAL_INSTAGRAM, SOCIAL_LINKEDIN, SOCIAL_YOUTUBE, SOCIAL_TIKTOK,
  FOOTER_COPYRIGHT, FOOTER_MENTIONS_URL, FOOTER_CGV_URL, FOOTER_CONFIDENTIALITE_URL,
  MAUTIC_FORM_NEWSLETTER_ID,
} from '../../config';

const siteName = SITE_NAME;
const sitePhone = SITE_PHONE_DISPLAY;
const sitePhoneRaw = SITE_PHONE;
const siteEmail = SITE_EMAIL;

const socialFacebook = SOCIAL_FACEBOOK;
const socialInstagram = SOCIAL_INSTAGRAM;
const socialLinkedin = SOCIAL_LINKEDIN;
---

<footer class="site-footer" role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
  <div class="site-footer__inner container">

    {/* Colonnes du footer */}
    <div class="site-footer__columns">

      {/* Colonne 1 : À propos */}
      <div class="site-footer__col">
        <h2 class="site-footer__heading">{siteName}</h2>
        <p class="site-footer__description">{SITE_DESCRIPTION}</p>

        {/* Réseaux sociaux */}
        <ul class="site-footer__social" role="list" aria-label="Réseaux sociaux">
          {socialFacebook && (
            <li>
              <a href={socialFacebook}
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="Facebook (nouvelle fenêtre)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                </svg>
              </a>
            </li>
          )}
          {socialInstagram && (
            <li>
              <a href={socialInstagram}
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="Instagram (nouvelle fenêtre)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            </li>
          )}
          {socialLinkedin && (
            <li>
              <a href={socialLinkedin}
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="LinkedIn (nouvelle fenêtre)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/>
                </svg>
              </a>
            </li>
          )}
          {SOCIAL_YOUTUBE && (
            <li>
              <a href={SOCIAL_YOUTUBE}
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="YouTube (nouvelle fenêtre)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20.06 12 20.06 12 20.06s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
                </svg>
              </a>
            </li>
          )}
          {SOCIAL_TIKTOK && (
            <li>
              <a href={SOCIAL_TIKTOK}
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="TikTok (nouvelle fenêtre)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.79a8.18 8.18 0 004.78 1.52V6.87a4.85 4.85 0 01-1.01-.18z"/>
                </svg>
              </a>
            </li>
          )}
        </ul>
      </div>

      {/* Colonne 2 : Liens rapides */}
      <div class="site-footer__col">
        <h2 class="site-footer__heading">Navigation</h2>
        <ul class="site-footer__links" role="list">
          <li><a href="/">Accueil</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/realisations">Réalisations</a></li>
          <li><a href="/a-propos">À propos</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      {/* Colonne 3 : Contact */}
      <div class="site-footer__col">
        <h2 class="site-footer__heading">Contact</h2>
        <address class="site-footer__contact" itemscope itemtype="https://schema.org/PostalAddress">
          <p itemprop="streetAddress" set:html={SITE_ADDRESS_HTML}></p>
          <p>
            <a href={`tel:${sitePhoneRaw}`} itemprop="telephone">
              {sitePhone}
            </a>
          </p>
          <p>
            <a href={`mailto:${siteEmail}`} itemprop="email">
              {siteEmail}
            </a>
          </p>
        </address>
      </div>

      {/* Colonne 4 : Newsletter Mautic */}
      <div class="site-footer__col">
        <h2 class="site-footer__heading">Newsletter</h2>
        <p class="site-footer__newsletter-desc">
          Recevez nos actualités et conseils.
        </p>
        <MauticForm formId={MAUTIC_FORM_NEWSLETTER_ID} formStyle="inline" />
      </div>

    </div>

    {/* Barre de copyright */}
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        {FOOTER_COPYRIGHT}
      </p>
      <ul class="site-footer__legal" role="list">
        <li><a href={FOOTER_MENTIONS_URL}>Mentions légales</a></li>
        {FOOTER_CGV_URL && <li><a href={FOOTER_CGV_URL}>CGV</a></li>}
        <li><a href={FOOTER_CONFIDENTIALITE_URL}>Politique de confidentialité</a></li>
      </ul>
    </div>

  </div>
</footer>
